; Maple Language Grammar (Draft v0.1)
; Status: Implemented baseline (validated in T14 closeout on 2026-03-21).
; Notes:
; - This grammar is normative for current Maple language behavior.
; - Closeout regression confirms parser/compiler alignment for covered syntax.

program         = { declaration } EOF ;

declaration     = classDecl
                | funDecl
                | varDecl
                | statement ;

classDecl       = "class" IDENTIFIER [ "<" IDENTIFIER ] "{" { methodDecl } "}" ;
methodDecl      = IDENTIFIER functionBody ;

funDecl         = "fun" IDENTIFIER functionBody ;
functionExpr    = "fun" functionBody ;
functionBody    = "(" [ parameters ] ")" block ;
parameters      = IDENTIFIER { "," IDENTIFIER } ;

varDecl         = "var" IDENTIFIER [ "=" expression ] statementEnd ;

statement       = exprStmt
                | printStmt
                | returnStmt
                | block
                | ifStmt
                | whileStmt
                | forStmt
                | importStmt
                | fromImportStmt ;

exprStmt        = expression statementEnd ;
printStmt       = "print" expression statementEnd ;
returnStmt      = "return" [ expression ] statementEnd ;
block           = "{" { declaration } "}" ;

ifStmt          = "if" "(" expression ")" statement [ "else" statement ] ;
whileStmt       = "while" "(" expression ")" statement ;

forStmt         = "for" "("
                  ( varDecl
                  | exprStmt
                  | clauseSep )
                  [ expression ] clauseSep
                  [ expression ]
                  ")" statement ;

importStmt      = "import" dottedName statementEnd ;
fromImportStmt  = "from" dottedName "import" IDENTIFIER [ "as" IDENTIFIER ] statementEnd ;

statementEnd    = ";" | NEWLINE ;
clauseSep       = ";" | NEWLINE ;

expression      = assignment ;

assignment      = ( call "." IDENTIFIER "=" assignment )
                | ( IDENTIFIER "=" assignment )
                | logicOr ;

logicOr         = logicAnd { "or" logicAnd } ;
logicAnd        = equality { "and" equality } ;

equality        = comparison { ( "==" | "!=" ) comparison } ;
comparison      = term { ( ">" | ">=" | "<" | "<=" ) term } ;
term            = factor { ( "+" | "-" ) factor } ;
factor          = unary { ( "*" | "/" ) unary } ;

unary           = ( "!" | "-" ) unary
                | call ;

call            = primary { callSuffix } ;
callSuffix      = "(" [ arguments ] ")"
                | "." IDENTIFIER ;
arguments       = expression { "," expression } ;

primary         = NUMBER
                | STRING
                | "true"
                | "false"
                | "nil"
                | "this"
                | "super" "." IDENTIFIER
                | IDENTIFIER
                | functionExpr
                | "(" expression ")" ;

dottedName      = IDENTIFIER { "." IDENTIFIER } ;

IDENTIFIER      = ? lexical identifier token ? ;
NUMBER          = ? lexical number token ? ;
STRING          = ? lexical string token ? ;
NEWLINE         = ? newline boundary token ? ;
EOF             = ? end-of-file token ? ;